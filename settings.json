{
  "lastChangelogVersion": "0.74.0",
  "defaultProvider": "openai-codex-personal",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "medium",
  "theme": "moonfly",
  "hideThinkingBlock": true,
  "packages": [
    "npm:pi-extmgr",
    "npm:pi-subagents",
    "npm:pi-mcp-adapter",
    "npm:pi-codex-web-search",
    "npm:pi-btw",
    "npm:pi-docparser",
    "git:github.com/earendil-works/pi-review",
    "git:https://github.com/SavingFrame/pi-diff-review",
    "npm:pi-ask-user",
    "npm:@benvargas/pi-claude-code-use",
    "git:github.com/edxeth/pi-gpt-config",
    "npm:@carlosgtrz/pi-codex-aliases"
  ],
  "transport": "auto",
  "collapseChangelog": false,
  "quietStartup": false,
  "editorPaddingX": 2,
  "terminal": {
    "showTerminalProgress": true
  },
  "gptConfig": {
    "fastMode": false,
    "personality": "claude",
    "verbosity": "low",
    "summary": "none",
    "toolDiscipline": "off",
    "showFooter": true
  },
  "treeFilterMode": "default"
}